{
  "name": "playwright-test",
  "version": "1.0.0",
  "description": "SingaPrinting production-safe hybrid E2E suite (Playwright + TypeScript + Allure)",
  "scripts": {
    "clean:reports": "rimraf playwright-report allure-report allure-results test-results",
    "pw:install": "playwright install chromium",
    "test:e2e": "playwright test",
    "test:smoke": "playwright test --grep \"@smoke\"",
    "test:auth": "playwright test --grep \"@auth\"",
    "test:visual": "playwright test --grep \"@visual\"",
    "test:update-visual": "cross-env UPDATE_VISUAL_BASELINE=true playwright test --grep \"@visual\"",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/pngjs": "^6.0.5",
    "allure-commandline": "^2.38.1",
    "allure-playwright": "^3.6.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.58.2",
    "pngjs": "^7.0.0",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
