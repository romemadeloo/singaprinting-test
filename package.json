{
  "name": "playwright-test",
  "version": "1.0.0",
  "description": "SingaPrinting production-safe functional E2E suite (Playwright + TypeScript + Allure)",
  "scripts": {
    "clean:reports": "rimraf playwright-report allure-report allure-results test-results",
    "pw:install": "playwright install chromium",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui --headed",
    "test:smoke": "npm run clean:reports && playwright test --grep \"@smoke\"",
    "test:auth": "playwright test --grep \"@auth\"",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "report": "npm run allure:generate && npm run allure:open",
    "clean:reports:": "rm -rf allure-results allure-report playwright-report test-results"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "allure-commandline": "^2.38.1",
    "allure-playwright": "^3.6.0",
    "dotenv": "^17.3.1",
    "playwright": "^1.58.2",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
